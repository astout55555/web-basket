# Copy to `.env` next to docker-compose.yml on the VM and fill in real
# values. NEVER commit the real .env — it holds the database password.

# Domain Caddy serves (must have an A record pointing at the VM's public IP).
DOMAIN=example.com

# Image the VM pulls (CI pushes it); leave unset for local builds.
APP_IMAGE=ghcr.io/your-github-username/web-basket-app:latest

# --- app ---
PORT=3000
# Behind Caddy the client IP arrives via X-Forwarded-For; trust it in prod.
TRUST_PROXY=true

# --- Azure SQL ---
AZURE_SQL_SERVER=your-server.database.windows.net
AZURE_SQL_PORT=1433
AZURE_SQL_DATABASE=webbasket
AZURE_SQL_USER=webbasket_app
AZURE_SQL_PASSWORD=change-me
# Azure SQL presents a real certificate — never trust-blindly in prod.
AZURE_SQL_TRUST_SERVER_CERT=false

# --- abuse limits / retention (defaults shown) ---
BODY_MAX_BYTES=262144
BASKET_REQUEST_CAP=200
BASKET_TTL_DAYS=7
BASKET_CREATE_PER_MINUTE=10
