{
  "name": "@web-basket/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "AZURE_SQL_TRUST_SERVER_CERT=true tsx watch src/server.ts",
    "build": "tsup",
    "start": "node dist/server.js",
    "db:migrate": "tsx src/db/migrate-cli.ts --ensure-db",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/static": "^10.1.0",
    "@web-basket/shared": "workspace:*",
    "fastify": "^5.10.0",
    "fastify-type-provider-zod": "^7.0.0",
    "mssql": "^12.7.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/mssql": "^12.3.0",
    "@types/node": "^26.1.1",
    "tsup": "^8.5.1",
    "tsx": "^4.23.1",
    "vitest": "^4.1.10"
  }
}
